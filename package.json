{
  "name": "spirit",
  "version": "0.1.0",
  "description": "精灵 — AI-driven log monitoring & auto-fix MCP platform",
  "type": "module",
  "scripts": {
    "mcp": "tsx src/mcp/index.ts",
    "watcher": "tsx src/watcher/index.ts",
    "watcher:dev": "tsx watch src/watcher/index.ts 2>&1 | tee spirit-$(date +%Y%m%d).log",
    "self-monitor": "tsx src/self-monitor/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@elastic/elasticsearch": "^8.17.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "better-sqlite3": "^11.8.0",
    "chokidar": "^4.0.0",
    "mysql2": "^3.12.0",
    "simple-git": "^3.27.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.0.0",
    "@vitest/ui": "^4.1.4",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  }
}
